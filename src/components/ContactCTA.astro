---
---

<section id="contacto" class="bg-[#1A1A1A] py-20 px-4">
  <div class="max-w-2xl mx-auto">

    <!-- Encabezado -->
    <div class="text-center mb-12">
      <span class="text-brand-green text-sm font-semibold uppercase tracking-widest">Empieza hoy</span>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
        Agenda tu llamada gratuita
      </h2>
      <p class="text-gray-400 text-lg">
        Un asesor experto te contactará en minutos para explicarte tus opciones sin compromiso.
      </p>
    </div>

    <!-- Formulario -->
    <form id="contact-form" class="bg-[#111111] border border-white/5 rounded-2xl p-8 space-y-5">

      <div>
        <label for="nombre" class="block text-sm font-medium text-gray-300 mb-2">Nombre completo</label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          placeholder="Tu nombre"
          class="w-full bg-[#1A1A1A] border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green transition-colors"
        />
      </div>

      <div>
        <label for="correo" class="block text-sm font-medium text-gray-300 mb-2">Correo electrónico</label>
        <input
          type="email"
          id="correo"
          name="correo"
          required
          placeholder="tu@correo.com"
          class="w-full bg-[#1A1A1A] border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green transition-colors"
        />
      </div>

      <div>
        <label for="whatsapp" class="block text-sm font-medium text-gray-300 mb-2">WhatsApp</label>
        <input
          type="tel"
          id="whatsapp"
          name="whatsapp"
          required
          placeholder="300 000 0000"
          class="w-full bg-[#1A1A1A] border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-brand-green focus:ring-1 focus:ring-brand-green transition-colors"
        />
      </div>

      <!-- Mensaje de error / éxito -->
      <div id="form-message" class="hidden text-sm px-4 py-3 rounded-xl"></div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-brand-green hover:bg-brand-green-dark text-white font-bold py-4 px-8 rounded-full transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_0_25px_rgba(116,191,3,0.3)] flex items-center justify-center gap-3 text-lg min-h-[56px]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Agendar mi llamada gratuita
      </button>

      <p class="text-center text-xs text-gray-500">
        Al enviar aceptas que un asesor te contacte por WhatsApp. Sin spam, sin compromiso.
      </p>
    </form>

  </div>
</section>

<!-- Botón flotante WhatsApp -->
<a
  href="https://wa.me/573XXXXXXXXX"
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 bg-[#25D366] hover:bg-[#1ebe57] text-white p-4 rounded-full shadow-2xl transition-all duration-300 hover:scale-110 hover:shadow-[0_0_20px_rgba(37,211,102,0.4)]"
  aria-label="Contactar por WhatsApp"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const WHATSAPP_NUMBER = '573XXXXXXXXX'; // Reemplazar con número real

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const msg = document.getElementById('form-message') as HTMLDivElement;

  function showMessage(text: string, isError: boolean) {
    msg.textContent = text;
    msg.className = `text-sm px-4 py-3 rounded-xl ${isError ? 'bg-red-500/10 border border-red-500/20 text-red-400' : 'bg-brand-green/10 border border-brand-green/20 text-brand-green'}`;
    msg.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nombre = (document.getElementById('nombre') as HTMLInputElement).value.trim();
    const correo = (document.getElementById('correo') as HTMLInputElement).value.trim();
    const whatsapp = (document.getElementById('whatsapp') as HTMLInputElement).value.trim();

    if (!nombre || !correo || !whatsapp) {
      showMessage('Por favor completa todos los campos.', true);
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      if (SUPABASE_URL && SUPABASE_ANON_KEY) {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/leads`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
            'Prefer': 'return=minimal',
          },
          body: JSON.stringify({ nombre, correo, whatsapp }),
        });

        if (!res.ok) throw new Error('Error al guardar');
      }

      showMessage('¡Listo! Redirigiendo a WhatsApp...', false);
      setTimeout(() => {
        const message = encodeURIComponent(`Hola, soy ${nombre}. Me registré en su sitio web y quisiera agendar una llamada gratuita para conocer mis opciones de crédito.`);
        window.location.href = `https://wa.me/${WHATSAPP_NUMBER}?text=${message}`;
      }, 1500);

    } catch {
      showMessage('Hubo un error. Por favor contáctanos directamente por WhatsApp.', true);
      btn.disabled = false;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> Agendar mi llamada gratuita`;
    }
  });
</script>
