---
const year = new Date().getFullYear();
---

<footer class="bg-[#0a0a0a] border-t border-white/5 py-12 px-4">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between gap-10 mb-10">

      <!-- Logo + descripción + redes -->
      <div class="max-w-xs">
        <img
          src="/logos/logo-oficial-blanco.webp"
          alt="Soluciones Financieras"
          class="h-20 w-auto object-contain mb-4"
        />
        <p class="text-gray-500 text-sm leading-relaxed mb-6">
          Más de 9 años ayudando a familias del Sur del Valle y Norte del Cauca a acceder al crédito justo.
        </p>

        <!-- Redes sociales -->
        <div class="flex items-center gap-3">
          <a
            href="https://www.instagram.com/solucionesfinancieras.co/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Síguenos en Instagram"
            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 border border-white/10 text-gray-400 hover:text-brand-green hover:border-brand-green/40 hover:bg-brand-green/5 transition-all duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=61557038523020"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Síguenos en Facebook"
            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 border border-white/10 text-gray-400 hover:text-brand-green hover:border-brand-green/40 hover:bg-brand-green/5 transition-all duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a
            href="https://www.tiktok.com/@solucionesfinanci89"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Síguenos en TikTok"
            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 border border-white/10 text-gray-400 hover:text-brand-green hover:border-brand-green/40 hover:bg-brand-green/5 transition-all duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
            </svg>
          </a>
          <a
            href="#"
            aria-label="LinkedIn — próximamente"
            title="Próximamente"
            class="w-10 h-10 flex items-center justify-center rounded-full bg-white/5 border border-white/10 text-gray-400 hover:text-brand-green hover:border-brand-green/40 hover:bg-brand-green/5 transition-all duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row gap-10">
        <div>
          <h5 class="text-white font-semibold text-sm mb-4">Navegación</h5>
          <ul class="space-y-2">
            <li><a href="#inicio" class="text-gray-500 hover:text-brand-green text-sm transition-colors">Inicio</a></li>
            <li><a href="#servicios" class="text-gray-500 hover:text-brand-green text-sm transition-colors">Servicios</a></li>
            <li><a href="#especialidades" class="text-gray-500 hover:text-brand-green text-sm transition-colors">Especialidades</a></li>
            <li><a href="#nosotros" class="text-gray-500 hover:text-brand-green text-sm transition-colors">Nosotros</a></li>
            <li><a href="#contacto" class="text-gray-500 hover:text-brand-green text-sm transition-colors">Contacto</a></li>
          </ul>
        </div>
        <div>
          <h5 class="text-white font-semibold text-sm mb-4">Servicios</h5>
          <ul class="space-y-2">
            <li><span class="text-gray-500 text-sm">Créditos por Libranza</span></li>
            <li><span class="text-gray-500 text-sm">Créditos para Independientes</span></li>
            <li><span class="text-gray-500 text-sm">Recuperación Crediticia</span></li>
            <li><span class="text-gray-500 text-sm">Asesoría Jurídica</span></li>
          </ul>
        </div>
        <div>
          <h5 class="text-white font-semibold text-sm mb-4">Contacto</h5>
          <ul class="space-y-2">
            <li class="text-gray-500 text-sm">Sur del Valle del Cauca</li>
            <li class="text-gray-500 text-sm">Norte del Cauca</li>
            <li>
              <a href="https://wa.me/573122918335" target="_blank" rel="noopener" class="text-brand-green hover:text-brand-green-light text-sm transition-colors">
                WhatsApp
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Divider + copyright -->
    <div class="border-t border-white/5 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-gray-600 text-xs">
        © {year} Soluciones Financieras. Todos los derechos reservados.
      </p>
      <p class="text-gray-600 text-xs">
        Servicio de intermediación financiera. No somos banco ni entidad financiera vigilada.
      </p>
    </div>

  </div>
</footer>
