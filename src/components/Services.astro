---
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`,
    title: 'Créditos por Libranza',
    description: 'Para pensionados, fuerzas armadas (Policía, Ejército, Armada, Fuerza Aérea), docentes y empleados públicos. Descuento directo de nómina.',
    tags: ['Pensionados', 'FF.AA.', 'Docentes'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>`,
    title: 'Créditos para Independientes',
    description: 'Con o sin Cámara de Comercio. Para trabajadores por cuenta propia que necesitan financiamiento ágil sin trámites complicados.',
    tags: ['Con CC', 'Sin CC'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Empleados con/sin Reportes',
    description: 'Aprobamos créditos incluso si tienes reportes en Datacrédito o CIFIN. Empleados del sector privado y público con o sin historial negativo.',
    tags: ['Sin reportes', 'Con reportes'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Recuperación de Vida Crediticia',
    description: 'Asesoría jurídica especializada para limpiar tu historial crediticio. Eliminamos reportes negativos con más de 8 años y mejoramos tu perfil.',
    tags: ['Asesoría legal', 'Limpieza +8 años'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    title: 'Servicios Complementarios',
    description: 'Gestión de cesantías y aportes a EPS. Orientación integral para que aproveches todos tus beneficios laborales y de seguridad social.',
    tags: ['EPS', 'Cesantías'],
  },
];
---

<section id="servicios" class="bg-[#111111] py-20 px-4">
  <div class="max-w-6xl mx-auto">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-brand-green text-sm font-semibold uppercase tracking-widest">Lo que ofrecemos</span>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
        Nuestros Servicios
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Soluciones financieras diseñadas para cada perfil. Ágiles, transparentes y con requisitos mínimos.
      </p>
    </div>

    <!-- Grid de cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="bg-[#1A1A1A] border border-white/5 rounded-2xl p-6 hover:border-brand-green/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-brand-green/5 group">
          <div class="text-brand-green mb-4 group-hover:scale-110 transition-transform duration-300 w-fit" set:html={service.icon} />
          <h3 class="font-heading text-lg font-bold text-white mb-3">{service.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-4">{service.description}</p>
          <div class="flex flex-wrap gap-2">
            {service.tags.map((tag) => (
              <span class="text-xs text-brand-green bg-brand-green/10 border border-brand-green/20 px-2.5 py-1 rounded-full font-medium">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
