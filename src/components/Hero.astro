<!--
  HERO — Mobile First (390px baseline)
  ─────────────────────────────────────
  Unprefixed  = mobile baseline (0 – 767px)  → locked to 390px design
  md:         = tablet  (768px+)              → constrained container, readable lines
  lg:         = desktop (1024px+)             → side-by-side layout

  H1: clamp(1.75rem, 5vw, 3rem) — fluid, capped at 3rem max
  P:  fixed 0.95rem mobile, md:max-w-xl + lg:max-w-[65ch] for 45-75 char lines
  White-line bug: -mt-[2px] + pt-[2px] overlap trick on content area
-->

<section id="inicio" class="relative overflow-hidden bg-[#1A1A1A] min-h-[100dvh] flex flex-col">

  <!-- ===== MOBILE/TABLET: Imagen arriba con fade ===== -->
  <div class="relative w-full h-[56vh] -mt-[72px] pt-[72px] lg:hidden">
    <img
      src="/images/hero-familia-movil.webp"
      alt="Familia pensionada feliz con Soluciones Financieras"
      class="block w-full h-full object-cover object-[center_20%]"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#1A1A1A] via-[#1A1A1A]/15 to-transparent"></div>
  </div>

  <!-- ===== DESKTOP: Imagen derecha con fade lateral ===== -->
  <div class="hidden lg:block absolute inset-y-0 right-0 w-[55%]">
    <img
      src="/images/hero-familia.webp"
      alt="Familia pensionada feliz con Soluciones Financieras"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#1A1A1A] via-[#1A1A1A]/60 to-transparent"></div>
  </div>

  <!-- Resplandor verde base -->
  <div class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-[#74BF04]/30 via-[#74BF04]/10 to-transparent pointer-events-none z-[5]"></div>

  <!-- ===== CONTENIDO ===== -->
  <!-- FIX white-line bug: -mt-[2px] pulls content up to overlap image edge, pt-[2px] compensates -->
  <div class="relative z-10 flex-1 flex items-center w-full
              -mt-[2px] pt-[2px]
              px-5 md:px-8 lg:px-10
              md:max-w-screen-md md:mx-auto
              lg:max-w-screen-xl lg:mx-auto">

    <div class="flex flex-col items-center text-center w-full
                py-8
                lg:items-start lg:text-left lg:w-[60%] lg:py-0">

      <!-- Badge — fixed size, no scaling -->
      <div class="mb-4 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-gray-300 text-[11px] md:text-xs font-medium whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-green flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
        <span>Especialistas en Pensionados, Fuerzas Armadas y Docentes</span>
      </div>

      <!-- Headline — fluid: 1.75rem @390 → 3rem @1024+ (capped) -->
      <h1 class="font-heading  font-extrabold text-white tracking-tight leading-[1.1]
                  mb-4 md:mt-2 md:mb-5
                  text-[clamp(1.75rem,5vw,3rem)]">
        Realiza tus planes hoy,
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-green-light to-brand-green">
          incluso si estás reportado.
        </span>
      </h1>

      <!-- Subtítulo — fixed mobile size, constrained width for readability on larger screens -->
      <p class="text-[0.95rem] text-gray-200 font-normal leading-relaxed
                mb-6 md:mb-8
                max-w-[300px]
                md:text-base md:max-w-xl md:mx-auto
                lg:text-xl lg:max-w-[65ch] lg:mx-0">
        Créditos ágiles por libranza y limpieza legal de historial crediticio. Más de 9 años de experiencia nos respaldan.
      </p>

      <!-- Beneficios — Liquid Glass pills -->
      <div class="flex flex-wrap justify-center lg:justify-start gap-2.5 mb-10 md:mb-12">
        <div class="glass-pill">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-green flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>Descuento por nómina</span>
        </div>
        <div class="glass-pill">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-green flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>Aprobamos con reportes</span>
        </div>
        <div class="glass-pill">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-brand-green flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>Limpieza de deudas (+8 años)</span>
        </div>
      </div>

      <!-- CTA + subtexto -->
      <div class=" flex flex-col items-center lg:items-start">
        <a
          href="#contacto"
          class="w-full md:w-auto inline-flex items-center justify-center gap-3.5
                 bg-brand-green hover:bg-brand-green-dark text-white
                 text-base font-bold
                 py-3.5 px-7 lg:py-4 lg:px-10 rounded-full
                 transition-all duration-300 hover:scale-105
                 hover:shadow-[0_0_30px_rgba(116,191,3,0.45)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Agendar mi llamada gratuita
        </a>
        <p class="mt-3 text-xs text-gray-200 lg:pl-10">
          Un asesor experto te contactará en minutos.
        </p>
      </div>

    </div>
  </div>

</section>

<style>
  .glass-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 10px;
    font-size: 11px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    white-space: nowrap;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.35),
      inset 0 -1px 0 rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
  }

  .glass-pill::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.6),
      transparent
    );
  }

  .glass-pill::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.6),
      transparent,
      rgba(255, 255, 255, 0.2)
    );
  }

  @media (min-width: 768px) {
    .glass-pill {
      font-size: 13px;
      padding: 9px 16px;
    }
  }
</style>
