---
const testimonials = [
  {
    name: 'Carlos M.',
    role: 'Pensionado — Cali, Valle',
    text: 'Tenía reportes en Datacrédito y pensé que nunca podría acceder a un crédito. Soluciones Financieras me ayudó a limpiar mi historial y conseguir el préstamo que necesitaba para mi negocio.',
    stars: 5,
    photo: null,
  },
  {
    name: 'Sandra P.',
    role: 'Docente oficial — Palmira, Valle',
    text: 'El proceso fue muy rápido y transparente. En menos de 48 horas ya tenía aprobado mi crédito por libranza. La atención fue excelente desde el primer momento.',
    stars: 5,
    photo: null,
  },
  {
    name: 'Suboficial J. R.',
    role: 'Ejército Nacional — Popayán, Cauca',
    text: 'Como militar retirado tenía dudas sobre si podía aplicar. Me explicaron todo con claridad y el descuento de nómina funciona perfecto. Los recomiendo al 100%.',
    stars: 5,
    photo: null,
  },
  {
    name: 'Jaime O.',
    role: 'Comerciante con Cámara de Comercio — Florida, Valle',
    text: 'Tengo mi negocio registrado y siempre al día con mis pagos. Necesitaba capital para crecer y aquí me dieron condiciones claras y transparentes. El crédito se aprobó más rápido de lo que esperaba.',
    stars: 5,
    photo: null,
  },
  {
    name: 'María L.',
    role: 'Independiente sin Cámara de Comercio — Buenaventura',
    text: 'Trabajo por mi cuenta y no tengo Cámara de Comercio, por eso pensé que no podría obtener un crédito. Me asesoraron paso a paso y conseguí el préstamo que necesitaba. Un equipo muy profesional y humano.',
    stars: 5,
    photo: null,
  },
  {
    name: 'Andrés G.',
    role: 'Empleado sector privado — Cali, Valle',
    text: 'Trabajo en una empresa privada y necesitaba un crédito sin trámites complicados. En menos de 48 horas tenía respuesta y la cuota se descuenta directo de mi nómina. Excelente atención desde el principio.',
    stars: 5,
    photo: null,
  },
];
---

<section class="bg-[#1A1A1A] py-20 px-4">
  <div class="max-w-7xl mx-auto">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-brand-green text-sm font-semibold uppercase tracking-widest">Lo que dicen nuestros clientes</span>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
        Testimonios
      </h2>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Cientos de familias ya lograron sus metas financieras con nuestra ayuda.
      </p>
    </div>

    <!-- Grid de testimonios -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <article class="bg-[#111111] border border-white/10 rounded-2xl overflow-hidden hover:border-brand-green/30 hover:shadow-[0_0_30px_rgba(116,191,3,0.08)] transition-all duration-300 flex flex-col">

          <!-- Foto / Placeholder -->
          <div class="relative aspect-[4/3] bg-gradient-to-br from-brand-blue/40 via-brand-blue-dark/30 to-brand-green/20 flex items-center justify-center overflow-hidden">
            {t.photo ? (
              <img
                src={t.photo}
                alt={`Foto de ${t.name}`}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            ) : (
              <>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_70%,rgba(116,191,3,0.18),transparent_60%)]"></div>
                <div class="relative w-24 h-24 rounded-full bg-white/10 backdrop-blur-sm border-2 border-white/25 flex items-center justify-center">
                  <span class="font-heading font-bold text-white text-4xl">{t.name.charAt(0)}</span>
                </div>
              </>
            )}

            <!-- Badge de estrellas -->
            <div class="absolute top-3 right-3 flex items-center gap-0.5 bg-black/55 backdrop-blur-md rounded-full px-2.5 py-1.5 border border-white/10">
              {Array.from({ length: t.stars }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-brand-green fill-brand-green" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              ))}
            </div>
          </div>

          <!-- Contenido -->
          <div class="p-6 flex flex-col flex-grow">

            <!-- Comilla decorativa -->
            <svg class="w-7 h-7 text-brand-green/40 mb-3 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
            </svg>

            <!-- Texto del testimonio -->
            <p class="text-gray-200 text-[15px] leading-relaxed mb-6 flex-grow">
              "{t.text}"
            </p>

            <!-- Autor -->
            <div class="border-t border-white/10 pt-4">
              <p class="text-white font-bold font-heading text-base">{t.name}</p>
              <p class="text-gray-300 text-sm mt-1 leading-snug">{t.role}</p>
            </div>

          </div>

        </article>
      ))}
    </div>

  </div>
</section>
