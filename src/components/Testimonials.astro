---
const testimonials = [
  {
    name: 'Carlos M.',
    role: 'Pensionado — Cali, Valle',
    text: 'Tenía reportes en Datacrédito y pensé que nunca podría acceder a un crédito. Soluciones Financieras me ayudó a limpiar mi historial y conseguir el préstamo que necesitaba para mi negocio.',
    stars: 5,
  },
  {
    name: 'Sandra P.',
    role: 'Docente oficial — Palmira, Valle',
    text: 'El proceso fue muy rápido y transparente. En menos de 48 horas ya tenía aprobado mi crédito por libranza. La atención fue excelente desde el primer momento.',
    stars: 5,
  },
  {
    name: 'Suboficial J. R.',
    role: 'Ejército Nacional — Popayán, Cauca',
    text: 'Como militar retirado tenía dudas sobre si podía aplicar. Me explicaron todo con claridad y el descuento de nómina funciona perfecto. Los recomiendo al 100%.',
    stars: 5,
  },
  {
    name: 'María L.',
    role: 'Empleada independiente — Buenaventura',
    text: 'Sin Cámara de Comercio y con reporte en CIFIN, me aprobaron el crédito. No lo podía creer. El equipo es muy profesional y humano.',
    stars: 5,
  },
];
---

<section class="bg-[#1A1A1A] py-20 px-4">
  <div class="max-w-6xl mx-auto">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-brand-green text-sm font-semibold uppercase tracking-widest">Lo que dicen nuestros clientes</span>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
        Testimonios
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Cientos de familias ya lograron sus metas financieras con nuestra ayuda.
      </p>
    </div>

    <!-- Grid de testimonios -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {testimonials.map((t) => (
        <div class="bg-[#111111] border border-white/5 rounded-2xl p-7 hover:border-brand-green/20 transition-all duration-300">

          <!-- Estrellas -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.stars }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-green fill-brand-green" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Texto -->
          <p class="text-gray-300 text-sm leading-relaxed mb-5 italic">"{t.text}"</p>

          <!-- Autor -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-green/20 border border-brand-green/30 flex items-center justify-center text-brand-green font-bold font-heading text-sm flex-shrink-0">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="text-white font-semibold text-sm">{t.name}</p>
              <p class="text-gray-500 text-xs">{t.role}</p>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
